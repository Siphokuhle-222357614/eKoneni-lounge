---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Page Not Found">
  <div class="min-h-[70vh] flex items-center justify-center px-5">
    <div class="text-center max-w-md">
      <div class="text-8xl font-display text-amber-400 mb-4">404</div>
      
      <h1 class="font-display text-4xl text-white mb-4">Page Not Found</h1>
      
      <p class="text-gray-400 text-lg mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" 
           class="px-8 py-3 rounded-full bg-amber-400 text-black font-medium hover:bg-amber-300 transition-colors">
          Go back home
        </a>
        
        <a href="#contact" 
           class="px-8 py-3 rounded-full border border-amber-400/30 text-amber-300 hover:bg-amber-400/10 transition-colors">
          Contact us
        </a>
      </div>
    </div>
  </div>
</MainLayout>