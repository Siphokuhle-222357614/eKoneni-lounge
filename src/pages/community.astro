---
import MainLayout from '../layouts/MainLayout.astro';
import CommunitySection from '../components/Community.astro';
---
<MainLayout
  title="Community"
  description="eKoneni Lounge gives back to Mdantsane — feeding children, rebuilding homes, and uplifting the community that made us."
>
  <!-- Page hero banner -->
  <div class="pt-28 sm:pt-36 pb-10 sm:pb-16 section-dark text-center px-5">
    <div class="flex items-center justify-center gap-3 mb-4">
      <span class="w-8 h-px bg-amber-400/40"></span>
      <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">eKoneni Lounge</span>
      <span class="w-8 h-px bg-amber-400/40"></span>
    </div>
    <h1 class="font-display text-5xl sm:text-6xl font-bold text-white">
      Community
    </h1>
  </div>
 
  <CommunitySection />
</MainLayout>
