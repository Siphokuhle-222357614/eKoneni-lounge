---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = "eKoneni Lounge – Where Mdantsane Grooves" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — eKoneni Lounge</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="text-gray-200">
  <Navbar />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Inline script to access DOM elements; using is:inline to bundle it -->
  <script is:inline src="/scripts/mobile-menu.js"></script>
</body>
</html>