---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "eKoneni Lounge | Amapiano nights, premium cocktails & township soul in Mdantsane, East London",
} = Astro.props;

const ogImage = "/images/lounge/hero-fallback.jpg";
const siteUrl = "https://ekoneni-lounge.netlify.app";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title} — eKoneni Lounge</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Plausible Analytics -->
    <script
      defer
      src="https://plausible.io/js/pa-0CKmc9UhJ1hfgfhMK6TFC.js?outbound-links=true&404=true"
    ></script>

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={`${title} — eKoneni Lounge`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/lounge/hero-fallback.jpg" />
    <meta property="og:site_name" content="eKoneni Lounge" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — eKoneni Lounge`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/lounge/hero-fallback.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Outfit:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="text-gray-200">
    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />

    <script is:inline src="/scripts/mobile-menu.js"></script>
  </body>

  <style is:global>
    html {
      scroll-behavior: smooth;
    }

    /* Optional: Better scroll offset for fixed navbar */
    html {
      scroll-padding-top: 80px;
    }
  </style>
</html>
