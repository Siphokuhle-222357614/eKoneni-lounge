---
// src/components/Reviews.astro
---
<section id="reviews" class="section-mid py-16 sm:py-20">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-10">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-8 h-px bg-amber-400/40"></span>
        <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">What People Say</span>
        <span class="w-8 h-px bg-amber-400/40"></span>
      </div>
      <span class="gold-line mx-auto"></span>
      <h2 class="section-heading text-4xl sm:text-5xl text-white">
        Real Stories.<br> 
        <span class="text-amber-400">Real Nights.</span>
      </h2>
      <p class="font-body text-gray-400 mt-3 max-w-md mx-auto">
        Don’t just take our word for it — here’s what our guests have to say.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Testimonial 1 -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="flex gap-1 mb-4 text-amber-400">
          ★★★★☆
        </div>
        <p class="font-body text-gray-300 leading-relaxed mb-6">
          “Best amapiano spot in Mdantsane by far. The energy is unmatched. We came for a birthday and ended up staying until 5am. The DJs were fire and the cocktails hit different.”
        </p>
        <div>
          <p class="font-medium text-white">Thando M.</p>
          <p class="text-sm text-gray-500">Regular • Mdantsane</p>
        </div>
      </div>

      <!-- Testimonial 2 -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="flex gap-1 mb-4 text-amber-400">
          ★★★★★
        </div>
        <p class="font-body text-gray-300 leading-relaxed mb-6">
          “I’ve performed at a lot of spots around East London. eKoneni is different. The crowd knows how to move and the sound system is proper. Always a good night.”
        </p>
        <div>
          <p class="font-medium text-white">DJ Murumba Pitch</p>
          <p class="text-sm text-gray-500">Artist • Frequent performer</p>
        </div>
      </div>

      <!-- Testimonial 3 -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="flex gap-1 mb-4 text-amber-400">
          ★★★★☆
        </div>
        <p class="font-body text-gray-300 leading-relaxed mb-6">
          “Came through for Fishbraai Thursday with my crew. The vibe was crazy, food was good, and they made us feel like family. We’re definitely making this a monthly thing.”
        </p>
        <div>
          <p class="font-medium text-white">Siphosethu &amp; friends</p>
          <p class="text-sm text-gray-500">Birthday celebration • June 2026</p>
        </div>
      </div>

      <!-- Testimonial 4 -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="flex gap-1 mb-4 text-amber-400">
          ★★★★★
        </div>
        <p class="font-body text-gray-300 leading-relaxed mb-6">
          “From the moment we walked in, the service was on point. The owner even came to greet us. Proper township luxury. This is now our go-to spot every weekend.”
        </p>
        <div>
          <p class="font-medium text-white">Noluthando K.</p>
          <p class="text-sm text-gray-500">East London • Regular</p>
        </div>
      </div>

    </div>

    <!-- CTA Button -->
    <div class="text-center mt-10">
      <a href="/contact" 
         onclick="prefillExperienceMessage()"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-amber-400/30 text-amber-300 hover:bg-amber-400/10 transition-colors text-sm font-body">
        Share your own experience →
      </a>
    </div>

  </div>
</section>

<script>
  function prefillExperienceMessage() {
    // Wait a bit for the page to scroll to the contact section
    setTimeout(() => {
      const messageField = document.getElementById('message');
      if (messageField) {
        messageField.value = "I'd like to share my experience at eKoneni.";
        messageField.focus();
      }
    }, 600); // Small delay so it feels natural
  }
</script>