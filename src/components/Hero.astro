---
// src/components/Hero.astro
---

<section
  id="home"
  class="relative overflow-hidden rounded-4xl mb-12
         sm:h-screen sm:flex sm:items-center sm:justify-center"
>
  <!-- Mobile Video -->
  <div class="block sm:hidden w-full aspect-video">
    <video
      src="/video/eKoneni-Lounge-Background-video.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="w-full h-full object-cover"
    ></video>
  </div>

  <!-- Desktop Video -->
  <video
    src="/video/eKoneni-Lounge-Background-video.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    class="hidden sm:block absolute inset-0 w-full h-full object-cover z-0"
    fetchpriority="high"
  ></video>

  <!-- Dark overlay -->
  <div class="hidden sm:block absolute inset-0 bg-black/60 z-[1]"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto text-center px-5">
    
    <!-- Brand -->
    <h1 class="font-display font-bold text-white text-4xl xs:text-5xl sm:text-6xl md:text-6xl mb-3">
      eKoneni Lounge
    </h1>

    <!-- Location tag -->
    <div class="hero-tag inline-flex items-center gap-2 rounded-full border border-amber-400/25 bg-amber-400/5 
                px-3 py-1 mb-5">
      <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
      <span class="font-body text-amber-300/90 tracking-[0.2em] uppercase text-xs">
        Mdantsane · East London · Est. 2019
      </span>
    </div>

    <!-- Headline -->
    <h2 class="font-display font-black text-white leading-none mb-5">
      <span class="block text-4xl xs:text-5xl sm:text-6xl md:text-6xl lg:text-6xl">
        Where Mdantsane
      </span>
      <span class="block text-4xl xs:text-5xl sm:text-6xl md:text-6xl lg:text-6xl text-amber-400"
            style="text-shadow: 0 0 80px rgba(251,191,36,0.4);">
        Truly Comes Alive.
      </span>
    </h2>

    <!-- Subheadline -->
    <p class="hero-sub font-body text-gray-300 max-w-2xl mx-auto leading-relaxed 
              text-base sm:text-xl mb-8">
      Premium amapiano nights, unforgettable energy, and a community that feels like family. 
      Every weekend, eKoneni turns Mdantsane into the place to be.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="#contact" 
         class="btn-gold rounded-full font-body tracking-wide px-8 py-3.5 text-sm sm:text-base w-full sm:w-auto text-center">
        Reserve Your Table
      </a>
      <a href="#events" 
         class="btn-outline rounded-full font-body tracking-wide px-8 py-3.5 text-sm sm:text-base w-full sm:w-auto text-center">
        See Upcoming Events
      </a>
    </div>
  </div>
</section>