                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.523 5.843L.057 23.882l6.198-1.427A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.865 9.865 0 01-5.031-1.378l-.36-.214-3.732.859.882-3.634-.235-.374A9.861 9.861 0 012.107 12C2.107 6.58 6.58 2.107 12 2.107S21.893 6.58 21.893 12 17.42 21.893 12 21.893z"></path>
