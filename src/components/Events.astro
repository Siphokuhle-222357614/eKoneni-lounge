---
// src/components/Events.astro
---

<section id="events" class="section-mid py-20 sm:py-24">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
    
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-3 mb-5">
        <span class="w-8 h-px bg-amber-400/40"></span>
        <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">Upcoming Nights</span>
        <span class="w-8 h-px bg-amber-400/40"></span>
      </div>
      <span class="gold-line mx-auto"></span>
      <h2 class="section-heading text-4xl sm:text-5xl text-white">
        Mark Your <span class="text-amber-400">Calendar</span>
      </h2>
      <p class="font-body text-gray-400 mt-4 max-w-md mx-auto">
        These nights have become part of Mdantsane’s rhythm. Book early.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">

      <!-- Event 1 -->
      <a href="/events/fishbraai-thursday" class="event-card card-lift rounded-2xl overflow-hidden flex flex-col no-underline">
        <div class="h-2 bg-gradient-to-r from-amber-400 to-amber-600"></div>
        <img src="/images/lounge/Fishbraai-thursday(celebrity).jpg" alt="Fishbraai Thursday" class="w-full h-56 object-cover" />
        <div class="p-6 flex flex-col flex-1">
          <h3 class="font-display text-2xl text-white font-bold mb-2">Fishbraai Thursday</h3>
          <p class="font-body text-amber-300/70 text-sm mb-5 flex-1">
            The warmest night of the week. Slow-burning amapiano, smoky braai aroma, and that unmistakable township feeling.
          </p>
          <div class="mt-auto space-y-1.5 text-sm text-gray-300 font-body">
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Thursday, 18 June 2026 · 21:00 – 04:00</div>
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Main Floor</div>
          </div>
        </div>
      </a>

      <!-- Event 2 (Featured) -->
      <a href="/events/amapiano-fridays" class="event-card card-lift rounded-2xl overflow-hidden flex flex-col relative border border-amber-400/20 no-underline" 
         style="box-shadow: 0 0 60px rgba(251,191,36,0.08);">
        <div class="h-2 bg-gradient-to-r from-amber-300 via-amber-400 to-amber-500"></div>
        <img src="/images/lounge/Bad-Decision-Tracy-and-Thatohatsi.jpg" alt="Amapiano Friday" class="w-full h-56 object-cover" />
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-2">
            <h3 class="font-display text-2xl text-white font-bold">Amapiano Fridays</h3>
            <span class="px-2.5 py-0.5 text-[10px] font-medium rounded-full bg-amber-400/10 text-amber-400 border border-amber-400/30">Featured</span>
          </div>
          <p class="font-body text-amber-300/70 text-sm mb-5 flex-1">
            The heartbeat of Mdantsane. When the best DJs in the game take over and the dancefloor stays full until sunrise.
          </p>
          <div class="mt-auto space-y-1.5 text-sm text-gray-300 font-body">
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Friday, 19 June 2026 · 21:00 – 04:00</div>
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Main Floor + VIP</div>
          </div>
        </div>
      </a>

      <!-- Event 3 -->
      <a href="/events/sunday-soul-session" class="event-card card-lift rounded-2xl overflow-hidden flex flex-col no-underline">
        <div class="h-2 bg-gradient-to-r from-amber-400 to-amber-600"></div>
        <img src="/images/lounge/Feel-so-good-sunday.jpg" alt="Sunday Soul Session" class="w-full h-56 object-cover" />
        <div class="p-6 flex flex-col flex-1">
          <h3 class="font-display text-2xl text-white font-bold mb-2">Sunday Soul Session</h3>
          <p class="font-body text-amber-300/70 text-sm mb-5 flex-1">
            Slow down, eat well, and let smooth amapiano carry you into the new week.
          </p>
          <div class="mt-auto space-y-1.5 text-sm text-gray-300 font-body">
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Sunday, 21 June 2026 · 14:00 – 22:00</div>
            <div class="flex items-center gap-2"><span class="text-amber-500">●</span> Main Floor + Outdoor</div>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>