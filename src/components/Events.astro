        <div class="h-2 bg-gradient-to-r from-amber-400 to-amber-600"></div>
        <img 
          src="/images/lounge/Feel-so-good-sunday.jpg" 
          alt="Sunday session flyer" 
          class="w-full h-56 object-cover"
        />
        <div class="p-6 flex flex-col flex-1">
          <h3 class="font-display text-2xl text-white font-bold mb-1">Sunday Soul Session</h3>
          <p class="font-body text-amber-300/70 text-sm mb-4 flex-1">
