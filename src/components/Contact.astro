---
// Contact section (home page and standalone)
---
<section id="contact" class="section-mid py-20 sm:py-28">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <div class="text-center mb-14">
      <div class="flex items-center justify-center gap-3 mb-5">
        <span class="w-8 h-px bg-amber-400/40"></span>
        <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">Find Us</span>
        <span class="w-8 h-px bg-amber-400/40"></span>
      </div>
      <span class="gold-line mx-auto"></span>
      <h2 class="section-heading text-4xl sm:text-5xl text-white">Get In <span class="text-amber-400">Touch</span></h2>
      <p class="font-body text-gray-500 mt-4 max-w-lg mx-auto text-sm sm:text-base">
        Reserve your table, ask about events, or just say <span class="text-amber-300/70">sawubona</span>.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Hours Card -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Business Hours</h3>
        <div class="space-y-2.5 font-body text-sm">
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Mon – Thu</span>
            <span class="text-gray-500">Closed</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Friday</span>
            <span class="text-amber-300/80">21:00 – 04:00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Saturday</span>
            <span class="text-amber-300/80">20:00 – 05:00</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="text-gray-400">Sunday</span>
            <span class="text-amber-300/80">14:00 – 22:00</span>
          </div>
        </div>
      </div>

      <!-- Location Card -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Location</h3>
        <div class="space-y-3 font-body text-sm text-gray-400">
          <p class="leading-relaxed">
            <span class="text-amber-200/80 font-medium block mb-0.5">eKoneni Lounge</span>
            3097 NU1<br/>
            Mdantsane, Unit 7<br/>
            East London, 5219<br/>
            Eastern Cape, South Africa
          </p>
          <a href="https://maps.google.com/?q=Mdantsane+East+London+South+Africa" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 text-amber-400 hover:text-amber-300 transition-colors text-xs tracking-wide">
            View on Google Maps
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact / WhatsApp Card -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Contact Us</h3>
        <div class="space-y-4 font-body text-sm text-gray-400">
          <div>
            <span class="text-gray-600 text-xs tracking-wide uppercase block mb-1">Phone</span>
            <a href="tel:+27432000000" class="text-gray-300 hover:text-amber-400 transition-colors">+27 43 200 0000</a>
          </div>
          <div>
            <span class="text-gray-600 text-xs tracking-wide uppercase block mb-1">Email</span>
            <a href="mailto:ekonenibutchery@gmail.com" class="text-gray-300 hover:text-amber-400 transition-colors">ekonenibutchery@gmail.com</a>
          </div>
          <div class="pt-2">
            <a href="https://wa.me/27432000000?text=Sawubona!%20I'd%20like%20to%20book%20a%20table%20at%20eKoneni%20Lounge." target="_blank" rel="noopener"
               class="wa-pulse inline-flex items-center gap-2.5 bg-green-900/30 border border-green-500/25 hover:border-green-400/50 hover:bg-green-900/50 transition-all rounded-xl px-4 py-3 w-full justify-center">
              <svg viewBox="0 0 24 24" class="w-5 h-5 fill-green-400" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span class="text-green-300 font-medium text-sm">WhatsApp Us</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>