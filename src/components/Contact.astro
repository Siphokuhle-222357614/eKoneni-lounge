---
// src/components/Contact.astro
---

<section id="contact" class="section-mid py-16 sm:py-20">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
    
    <!-- Header -->
    <div class="text-center mb-10">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-8 h-px bg-amber-400/40"></span>
        <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">Find Us</span>
        <span class="w-8 h-px bg-amber-400/40"></span>
      </div>
      <span class="gold-line mx-auto"></span>
      <h2 class="section-heading text-4xl sm:text-5xl text-white">
        Get In <span class="text-amber-400">Touch</span>
      </h2>
      <p class="font-body text-gray-400 mt-3 max-w-lg mx-auto text-sm sm:text-base">
        Contact us, ask about events, or just say <span class="text-amber-300/70">sawubona</span>.
      </p>
    </div>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      
      <!-- Hours Card -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"></path>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Business Hours</h3>
        <div class="space-y-2.5 font-body text-sm">
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Mon – Thu</span>
            <span class="text-gray-500">Closed</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Friday</span>
            <span class="text-amber-300/80">21:00 – 04:00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-amber-400/8">
            <span class="text-gray-400">Saturday</span>
            <span class="text-amber-300/80">20:00 – 05:00</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="text-gray-400">Sunday</span>
            <span class="text-amber-300/80">14:00 – 22:00</span>
          </div>
        </div>
      </div>

      <!-- Location Card -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Location</h3>
        <div class="space-y-3 font-body text-sm text-gray-400">
          <p class="leading-relaxed">
            <span class="text-amber-200/80 font-medium block mb-0.5">eKoneni Lounge</span>
            3097 NU1<br />
            Mdantsane, Unit 7<br />
            East London, 5219<br />
            Eastern Cape, South Africa
          </p>
          <a href="https://maps.google.com/?q=Mdantsane+East+London+South+Africa" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-amber-400 hover:text-amber-300 transition-colors text-xs tracking-wide">
            View on Google Maps
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Contact Info + WhatsApp -->
      <div class="contact-card card-lift rounded-2xl p-7">
        <div class="w-11 h-11 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </div>
        <h3 class="font-display text-xl text-white font-bold mb-4">Contact Us</h3>

        <div class="space-y-4 font-body text-sm text-gray-400 mb-6">
          <div>
            <span class="text-gray-600 text-xs tracking-wide uppercase block mb-1">Phone</span>
            <a href="tel:+27432000000" class="text-gray-300 hover:text-amber-400 transition-colors">+27 43 200 0000</a>
          </div>
          <div>
            <span class="text-gray-600 text-xs tracking-wide uppercase block mb-1">Email</span>
            <a href="mailto:ekonenibutchery@gmail.com" class="text-gray-300 hover:text-amber-400 transition-colors">ekonenibutchery@gmail.com</a>
          </div>
        </div>

        <!-- WhatsApp Button -->
        <a href="https://wa.me/27432000000?text=Sawubona!%20I'd%20like%20to%20make%20a%20booking" target="_blank" rel="noopener noreferrer" 
           class="flex items-center justify-center gap-2 w-full py-3 rounded-xl border border-amber-400/30 bg-amber-400/10 font-body text-amber-300 text-sm hover:bg-amber-400/20 hover:border-amber-400/50 transition-all duration-200 mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.523 5.843L.057 23.882l6.198-1.427A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.865 9.865 0 01-5.031-1.378l-.36-.214-3.732.859.882-3.634-.235-.374A9.861 9.861 0 012.107 12C2.107 6.58 6.58 2.107 12 2.107S21.893 6.58 21.893 12 17.42 21.893 12 21.893z"></path>
          </svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>

    <!-- Booking Form -->
    <div class="max-w-3xl mx-auto">
      <div class="contact-card card-lift rounded-2xl p-8 sm:p-10">
        <h3 class="font-display text-2xl text-white font-bold mb-2 text-center">Make a Booking or Enquiry</h3>
        <p class="text-center text-gray-400 text-sm mb-8">Fill the form below and we’ll get back to you within a few hours.</p>

        <form name="contact" method="POST" data-netlify="true" class="space-y-5" id="contact-form">
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm text-gray-400 mb-1.5">Full Name</label>
              <input type="text" id="name" name="name" required class="w-full bg-black/40 border border-amber-400/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-amber-400/60 transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label for="phone" class="block text-sm text-gray-400 mb-1.5">Phone Number</label>
              <input type="tel" id="phone" name="phone" required class="w-full bg-black/40 border border-amber-400/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-amber-400/60 transition-colors" placeholder="+27 XX XXX XXXX" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm text-gray-400 mb-1.5">Email Address</label>
            <input type="email" id="email" name="email" required class="w-full bg-black/40 border border-amber-400/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-amber-400/60 transition-colors" placeholder="you@email.com" />
          </div>

          <div>
            <label for="event" class="block text-sm text-gray-400 mb-1.5">Date &amp; Event (optional)</label>
            <input type="text" id="event" name="event" class="w-full bg-black/40 border border-amber-400/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-amber-400/60 transition-colors" placeholder="e.g. Friday 19 June or Amapiano Friday" />
          </div>

          <div>
            <label for="message" class="block text-sm text-gray-400 mb-1.5">Message / Special Requests</label>
            <textarea id="message" name="message" rows="5" required class="w-full bg-black/40 border border-amber-400/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-amber-400/60 transition-colors resize-y min-h-[120px]" placeholder="How many people? VIP section? Any special requests?"></textarea>
          </div>

          <button type="submit" class="w-full py-3.5 rounded-xl bg-amber-400 hover:bg-amber-300 active:bg-amber-500 transition-all text-black font-medium tracking-wide text-sm font-body mt-2">
            Send Booking Request
          </button>

          <div id="form-status" aria-live="polite" class="text-center text-sm mt-2 min-h-[24px] transition-all duration-300 opacity-0"></div>
        </form>

        <script>
          const form = document.getElementById("contact-form");
          const status = document.getElementById("form-status");

          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            status.textContent = "Sending...";
            status.style.color = "#fbbf24";
            status.style.opacity = "1";

            const formData = new FormData(form);

            try {
              const response = await fetch("/", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: new URLSearchParams(formData).toString(),
              });

              if (response.ok) {
                status.textContent = "Thank you! Your booking request has been sent. We will contact you shortly.";
                status.style.color = "#4ade80";
                form.reset();
                setTimeout(() => {
                  status.style.transition = "all 0.5s ease";
                  status.style.opacity = "0";
                }, 6000);
              } else {
                throw new Error("Form submission failed");
              }
            } catch (error) {
              status.textContent = "Something went wrong. Please try again or message us on WhatsApp.";
              status.style.color = "#f87171";
            }
          });
        </script>
      </div>
    </div>
  </div>
</section>