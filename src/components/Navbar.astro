---
// src/components/Navbar.astro
---
<nav id="navbar" 
     class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" 
     style="background: rgba(13,10,5,0.92); backdrop-filter: blur(18px); border-bottom: 1px solid rgba(251,191,36,0.08);">
  
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
    <div class="flex items-center justify-between h-16 sm:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <img 
          src="/image2vector.svg" 
          alt="eKoneni Lounge" 
          width="150" 
          height="150" 
          class="w-[150px] h-[150px] object-contain drop-shadow-[0_0_12px_rgba(251,191,36,0.35)] group-hover:drop-shadow-[0_0_18px_rgba(251,191,36,0.55)] transition-all duration-300"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Home</a>
        <a href="/about" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">About</a>
        <a href="/events" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Events</a>
        <a href="/butchery" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Butchery</a>
        <a href="/gallery" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Gallery</a>
        <a href="/community" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Community</a>
        <a href="/reviews" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Reviews</a>
        <a href="/lost-found" class="nav-link font-body text-sm font-medium text-gray-300 hover:text-amber-400">Lost & Found</a>
      </div>

      <!-- Desktop CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a href="/contact" class="hidden sm:inline-flex btn-gold px-5 py-2.5 rounded-full text-sm font-body">
          Contact Us
        </a>

        <!-- Hamburger -->
        <button id="menu-btn" onclick="toggleMenu()" 
                class="md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 focus:outline-none">
          <span class="block w-6 h-0.5 bg-amber-400 transition-all duration-300" id="bar1"></span>
          <span class="block w-5 h-0.5 bg-amber-400 transition-all duration-300" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-amber-400 transition-all duration-300" id="bar3"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" style="background: rgba(13,10,5,0.97); border-top: 1px solid rgba(251,191,36,0.10); display: none;">
    <div class="px-6 py-6 flex flex-col gap-5">
      <a href="/" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Home</a>
      <a href="/about" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">About</a>
      <a href="/events" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Events</a>
      <a href="/butchery" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Butchery</a>
      <a href="/gallery" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Gallery</a>
      <a href="/community" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Community</a>
      <a href="/reviews" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Reviews</a>
      <a href="/lost-found" onclick="toggleMenu()" class="font-body text-gray-300 hover:text-amber-400 transition-colors py-1.5">Lost & Found</a>
      <a href="/contact" onclick="toggleMenu()" class="btn-gold px-5 py-3 rounded-full text-sm text-center font-body mt-1">Contact Us</a>
    </div>
  </div>
</nav>

<!-- Floating Menu Button (appears when scrolling down) -->
<button id="floating-menu-btn"
        class="hidden fixed bottom-6 right-6 z-[60] w-14 h-14 rounded-full bg-amber-400 text-black flex items-center justify-center shadow-lg hover:bg-amber-300 transition-all active:scale-95 md:hidden">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<script>
  // Navbar hide on scroll
  let lastScrollY = window.scrollY;
  const navbar = document.getElementById('navbar');
  const floatingBtn = document.getElementById('floating-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    // Hide navbar when scrolling down
    if (currentScrollY <= 10) {
      navbar.style.transform = 'translateY(0)';
    } else if (currentScrollY < lastScrollY) {
      navbar.style.transform = 'translateY(0)';
    } else {
      navbar.style.transform = 'translateY(-100%)';
    }

    // Show floating menu button after scrolling
    if (currentScrollY > 300) {
      floatingBtn.classList.remove('hidden');
      floatingBtn.classList.add('flex');
    } else {
      floatingBtn.classList.add('hidden');
      floatingBtn.classList.remove('flex');
    }

    lastScrollY = currentScrollY;
  });

  // Floating Menu Button - Opens mobile menu
  if (floatingBtn && mobileMenu) {
    floatingBtn.addEventListener('click', () => {
      if (mobileMenu.style.display === 'block') {
        mobileMenu.style.display = 'none';
      } else {
        mobileMenu.style.display = 'block';
      }
    });
  }

  // Original Hamburger Menu Toggle
  function toggleMenu() {
    if (mobileMenu.style.display === 'block') {
      mobileMenu.style.display = 'none';
    } else {
      mobileMenu.style.display = 'block';
    }
  }

  // Make toggleMenu available globally (in case it's needed)
  window.toggleMenu = toggleMenu;
</script>