---
// src/components/Butchery.astro
---
<section class="section-mid py-20 sm:py-28">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="flex items-center justify-center gap-3 mb-5">
        <span class="w-8 h-px bg-amber-400/40"></span>
        <span class="font-body text-amber-500 text-xs tracking-[0.25em] uppercase">Quality &amp; Tradition</span>
        <span class="w-8 h-px bg-amber-400/40"></span>
      </div>
      <span class="gold-line mx-auto"></span>
      <h2 class="section-heading text-4xl sm:text-5xl text-white">
        eKoneni <span class="text-amber-400">Butchery</span>
      </h2>
      <p class="font-body text-gray-400 mt-4 max-w-lg mx-auto">
        Premium cuts. Local flavour. Perfect for every great night at the lounge.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">

      <!-- Content -->
      <div class="space-y-6">
        <p class="font-body text-gray-300 text-lg leading-relaxed">
          Our butchery was born from the same passion that built eKoneni Lounge. We source and prepare only the best quality meat — perfect for your braai, celebrations, or private events at the lounge.
        </p>

        <div class="pt-2">
          <a href="#offerings" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-amber-400/30 text-amber-300 hover:bg-amber-400/10 transition-colors text-sm font-body">
            See our offerings →
          </a>
        </div>
      </div>

      <!-- Image / Video -->
      <div class="relative">
        <div class="rounded-3xl overflow-hidden aspect-[4/3] border border-amber-400/10">
          <video 
            src="/video/Butchery-video.mp4" 
            class="w-full h-full object-cover"
            autoplay
            muted
            loop
            playsinline
          />
        </div>
      </div>

    </div>

    <!-- Our Offerings Section -->
    <div id="offerings" class="mt-16">
      <div class="text-center mb-10">
        <h3 class="font-display text-3xl text-white">Our Offerings</h3>
        <p class="text-gray-400 mt-2">Quality meat for your table and events</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Premium Beef</h4>
          <p class="text-gray-400 text-sm">Tender, well-aged cuts perfect for braai and special occasions.</p>
        </div>

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Lamb &amp; Goat</h4>
          <p class="text-gray-400 text-sm">Fresh and flavourful — ideal for traditional gatherings and celebrations.</p>
        </div>

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Chicken</h4>
          <p class="text-gray-400 text-sm">Quality whole and portioned chicken, always fresh and ready.</p>
        </div>

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Braai Combos</h4>
          <p class="text-gray-400 text-sm">Curated meat packs designed for groups, families, and celebrations.</p>
        </div>

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Weekly Specials</h4>
          <p class="text-gray-400 text-sm">Limited-time offers on selected cuts. Ask us what’s currently on promotion.</p>
        </div>

        <div class="rounded-2xl border border-amber-400/10 bg-black/30 p-7">
          <h4 class="font-display text-2xl text-white mb-3">Event Catering</h4>
          <p class="text-gray-400 text-sm">We supply quality meat for private bookings and functions at eKoneni Lounge.</p>
        </div>

      </div>

      <div class="text-center mt-10">
        <a href="#contact" 
           class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-amber-400 text-black font-medium text-sm tracking-wide hover:bg-amber-300 transition-colors">
          Order for your event or braai →
        </a>
      </div>
    </div>

  </div>
</section>